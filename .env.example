# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# HTTP
CORS_ORIGIN=http://localhost:5173
BODY_SIZE_LIMIT=100kb

# Database (Neon) — required when Prisma is wired
# DATABASE_URL=
# DIRECT_URL=

# Auth — required when auth module is implemented
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# BCRYPT_COST=12
# COOKIE_DOMAIN=
# COOKIE_SECURE=false

# Uploads (Vercel Blob)
# BLOB_READ_WRITE_TOKEN=

# Jobs
# CRON_SECRET=

# Rate limit (production / Upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
