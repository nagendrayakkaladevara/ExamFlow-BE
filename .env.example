# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# HTTP
CORS_ORIGIN=http://localhost:5173
BODY_SIZE_LIMIT=100kb

# Database (Neon)
# Pooled connection for runtime (Prisma Neon adapter)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
# Direct connection for migrations (remove -pooler from hostname)
DIRECT_URL=postgresql://user:password@host/neondb?sslmode=require

# Auth — required in production
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
# COOKIE_DOMAIN=

# Uploads (Vercel Blob) — required in production
BLOB_READ_WRITE_TOKEN=

# Jobs — required in production
CRON_SECRET=

# Seed (local development only)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=Admin123!

# Rate limit (production / Upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
