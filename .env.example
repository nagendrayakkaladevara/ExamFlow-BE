# Local development defaults — copy to `.env` and fill in values.
# Vercel Production — copy from `.env.production` into Vercel Environment Variables.

# ─── Runtime ───
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── HTTP ───
# Local: http://localhost:5173
# Production: https://your-frontend.vercel.app (comma-separate multiple origins)
CORS_ORIGIN=http://localhost:5173
BODY_SIZE_LIMIT=100kb

# ─── Database (Neon) ───
# Pooled connection for runtime (hostname contains -pooler)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct connection for migrations (no -pooler)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── Auth (required in production on Vercel) ───
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Local: false | Production (HTTPS): true
COOKIE_SECURE=false
# COOKIE_DOMAIN=

# ─── Uploads (Vercel Blob) — required for file uploads in production ───
BLOB_READ_WRITE_TOKEN=

# ─── Jobs (required in production on Vercel) ───
CRON_SECRET=

# ─── Seed (local development only — never set on Vercel) ───
# SEED_ADMIN_EMAIL=admin@svecw.edu.in
# SEED_ADMIN_PASSWORD=admin1

# ─── Rate limit (optional — Upstash for production serverless) ───
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
